# ============================================================
# NVIDIA NIM
# ============================================================
NVIDIA_API_KEY=nvapi-****************************
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# ============================================================
# REDIS CACHE
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finbot
POSTGRES_USER=finbot_user
POSTGRES_PASSWORD=finbot_pass

# ============================================================
# VECTOR STORE (ChromaDB)
# ============================================================
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_REPORTS=financial_reports
CHROMA_COLLECTION_NEWS=stock_news

# ============================================================
# API SERVER
# ============================================================
API_HOST=0.0.0.0
API_PORT=8080
API_DEBUG=false

# ============================================================
# STOCK DATA SOURCES
# ============================================================
TCBS_BASE_URL=https://apipubaws.tcbs.com.vn
SSI_BASE_URL=https://fc-data.ssi.com.vn

# ============================================================
# NEWS SOURCES
# ============================================================
CAFEF_RSS=https://cafef.vn/thi-truong-chung-khoan.rss
VNECONOMY_RSS=https://vneconomy.vn/chung-khoan.rss

# ============================================================
# APP SETTINGS
# ============================================================
LOG_LEVEL=INFO
CACHE_TTL_PRICE=300
CACHE_TTL_COMPANY=86400
CACHE_TTL_NEWS=1800
MAX_TOKENS_PER_REQUEST=4096
